# ============================================
# LinhKienLed1000 - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# Required variables are marked with [REQUIRED]
# ============================================

# [REQUIRED] PostgreSQL connection string
DATABASE_URL="postgresql://admin:admin%40123@host.docker.internal:5432/db_dientu"

# [REQUIRED] Secret key for JWT token signing (use a random 32+ char string)
JWT_SECRET="change-this-to-a-random-secret"

# [REQUIRED] App URL (used for callbacks and webhooks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment (development | production)
NODE_ENV="development"

# ---- AI Provider ----
# OpenAI API key - required for AI-powered responses
OPENAI_API_KEY="sk-your-openai-api-key"

# ---- Phone Channel (Twilio + ElevenLabs) ----
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# ---- Webhook Security ----
# Secret key for HMAC-SHA256 webhook payload signatures
WEBHOOK_SECRET="change-this-to-a-random-secret"

# ---- Meta / Facebook / Instagram Messaging ----
# Verify token used by Meta webhook verification
META_VERIFY_TOKEN="change-this-meta-webhook-verify-token"
META_GRAPH_VERSION="v25.0"
META_WEBHOOK_EVENT_TIMEOUT_MS="8000"
META_SEND_MAX_RETRIES="2"
META_MAX_MESSAGE_LENGTH="1800"
FACEBOOK_PAGE_ACCESS_TOKEN=""
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_BUSINESS_ACCOUNT_ID=""
# Optional: verifies x-hub-signature-256 on incoming webhook POST requests
META_APP_SECRET=""

# ---- CORS (optional) ----
# Set to allow cross-origin API access (e.g., "https://your-frontend.com")
# CORS_ORIGIN=""

# ---- Optional ----
NEXTAUTH_SECRET="change-this-to-a-random-secret"
